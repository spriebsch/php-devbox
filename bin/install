#!/bin/bash

set -e

if [ ! -f "bin/install" ]; then
  echo "Error: call this script from the php-devbox directory"
  exit 1
fi

source bin/build

source=$(dirname "$(dirname "$(readlink -f "$0")")")

if [ -f "/usr/local/bin/php-devbox" ]; then
  sudo rm /usr/local/bin/php-devbox
fi

sudo ln -s $source/bin/php-devbox /usr/local/bin
sudo cp scripts/show-coverage /usr/local/bin
