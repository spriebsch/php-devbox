#!/bin/bash

if command -v podman &> /dev/null; then
    COMMAND=podman
elif command -v docker &> /dev/null; then
    COMMAND=docker
else
    echo "Error: Neither podman nor docker found. Please install one of them."
    exit 1
fi

if [ $# -gt 0 ]; then
    CONTAINER_CMD=("$@")
else
    CONTAINER_CMD=("bash")
fi

"$COMMAND" run -it --rm \
  --hostname php-devbox \
  -v "$(pwd)":/workspace \
  -w /workspace \
  php-devbox:latest \
  "${CONTAINER_CMD[@]}"
